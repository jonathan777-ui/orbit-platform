# Copy to .env and adjust as needed:  cp .env.example .env

# Public-facing base URL n8n uses for webhooks / MCP endpoints.
# Keep the trailing slash. Change if you tunnel (e.g. an ngrok URL).
WEBHOOK_URL=http://localhost:5678/

# Hostname n8n binds its UI/links to.
N8N_HOST=localhost

# Your timezone (IANA name) for schedules.
GENERIC_TIMEZONE=America/New_York

# OPTIONAL but recommended: a fixed encryption key so saved credentials
# survive a volume wipe and are portable between machines. Generate one:
#   openssl rand -hex 24
N8N_ENCRYPTION_KEY=
